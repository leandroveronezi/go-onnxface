# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.so.*
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

/.idea/
/.history/
/examples/go.sum
/go.sum

# onnxruntime shared library -- large platform-specific binary, not
# checked in. See README for how to obtain it.
/onnxruntime/

# Model weights -- not checked in (see the README's Licensing and
# Development sections for why, and how to fetch them: DownloadModels,
# <engine>.DownloadModel, or curl directly for local dev).
/models/*

